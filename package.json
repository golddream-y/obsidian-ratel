{
	"name": "ratel-vault",
	"version": "0.1.0",
	"description": "Harness-driven knowledge base agent for your Obsidian vault",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"svelte-check": "svelte-check --tsconfig tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"link:vault": "node scripts/link-vault.mjs",
		"link:dev": "npm run build && npm run link:vault --",
		"unlink:vault": "node scripts/link-vault.mjs --unlink"
	},
	"keywords": [
		"obsidian",
		"agent",
		"rag",
		"knowledge-base",
		"harness"
	],
	"license": "MIT",
	"overrides": {
		"vectra": {
			"@huggingface/transformers": false
		},
		"@huggingface/transformers": false,
		"onnxruntime-node": false
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.3",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.1.1",
		"obsidian": "latest",
		"svelte": "^5.33.3",
		"svelte-check": "^4.2.1",
		"svelte-preprocess": "^6.0.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"dompurify": "^3.4.11",
		"highlight.js": "^11.11.1",
		"ignore": "^7.0.5",
		"marked": "^18.0.5",
		"marked-highlight": "^2.2.4",
		"mermaid": "^11.16.0",
		"onnxruntime-web": "^1.27.0",
		"vectra": "^0.15.0"
	}
}
